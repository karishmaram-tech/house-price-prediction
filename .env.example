# ═══════════════════════════════════════════════════
#  EstateIQ — Environment Variables Template
#
#  INSTRUCTIONS FOR NEW DEVELOPERS:
#  1. Copy this file: cp .env.example .env
#  2. Fill in the values in your new .env file
#  3. Never commit the .env file to Git
#
#  This file IS safe to commit. It contains no secrets.
# ═══════════════════════════════════════════════════

# Flask core settings
# Generate a real secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
DEBUG=False
PORT=7860

# Logging — options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Model
MODEL_PATH=model/house_price_model.pkl

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=50
RATE_LIMIT_PER_DAY=200

# App metadata
APP_NAME=EstateIQ
APP_VERSION=1.0.0
ENVIRONMENT=development